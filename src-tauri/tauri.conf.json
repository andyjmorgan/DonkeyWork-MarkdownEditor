{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Markdown Editor",
  "version": "1.0.0",
  "identifier": "com.donkeywork.markdowneditor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Markdown Editor",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "exceptionDomain": null,
      "signingIdentity": "Developer ID Application: AndrewMorgan Ltd. (NYG9V7955H)",
      "providerShortName": "NYG9V7955H",
      "entitlements": "Entitlements.plist"
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown text document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "shortDescription": "A beautiful markdown WYSIWYG editor",
    "longDescription": "A beautiful, minimalistic markdown editor with live preview, split view editing, and Mermaid diagram support.",
    "copyright": "© 2026 DonkeyWork",
    "category": "DeveloperTool",
    "publisher": "DonkeyWork"
  }
}
